# OpenAI Realtime (bridge-worker secrets — also set via `wrangler secret put`)
OPENAI_API_KEY=
OPENAI_WEBHOOK_SECRET=
OPENAI_PROJECT_ID=proj_...

# Twilio test rig (parallel migration — optional while moving to SignalWire)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# SignalWire (swsh + REST API)
# Space = subdomain only, e.g. "yourspace" from https://yourspace.signalwire.com
SIGNALWIRE_SPACE=
# Project ID from Dashboard → API (UUID, not the OpenAI proj_ id)
SIGNALWIRE_PROJECT_ID=
# REST API token from Dashboard → API → Create Token
# swsh reads REST_API_TOKEN; SIGNALWIRE_API_KEY is accepted as an alias by repo scripts
SIGNALWIRE_API_KEY=
REST_API_TOKEN=

# Optional: gateway SIP peer hints (entered in app UI, not read by scripts)
# SIGNALWIRE_SIP_DOMAIN=yourapp.dapp.signalwire.com
# SIGNALWIRE_SIP_USERNAME=
# SIGNALWIRE_SIP_PASSWORD=
